{
  "permissions": {
    "allow": [
      "Bash(git checkout -b *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(gh pr create*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f && [[ \"$f\" == *.py ]] && command -v ruff >/dev/null 2>&1 && ruff check --fix \"$f\"; } 2>/dev/null || true",
            "statusMessage": "ruff check --fix"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f && { [[ \"$f\" == *.vue ]] || [[ \"$f\" == *.ts ]]; } && [ -x \"./frontend/node_modules/.bin/eslint\" ] && ./frontend/node_modules/.bin/eslint --fix \"$f\"; } 2>/dev/null || true",
            "statusMessage": "eslint --fix"
          }
        ]
      }
    ]
  }
}
