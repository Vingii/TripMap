# Copy to .env and fill in real values before running:
#   docker compose -f docker-compose.prod.yml up -d

# Postgres credentials — used by both the db container and the app's DATABASE_URL.
POSTGRES_USER=tripmap
POSTGRES_PASSWORD=change-me
POSTGRES_DB=tripmap

# Allowed CORS origins as a JSON array, e.g. ["https://tripmap.example.com"].
CORS_ORIGINS=["http://localhost:8000"]

# App image tag. Defaults to vingii/tripmap:latest; pin to a release for stability.
# TRIPMAP_IMAGE=vingii/tripmap:v0.1.0

# Host port the app is exposed on.
# TRIPMAP_PORT=8000

# Geocoding (Nominatim). Defaults to the public OpenStreetMap instance; point this
# at a self-hosted Nominatim to avoid the public usage policy / rate limits.
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
